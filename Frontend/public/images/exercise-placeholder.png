<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 675" width="1200" height="675">
  <!-- Background -->
  <rect width="1200" height="675" fill="#f3f4f6"/>
  
  <!-- Subtle pattern -->
  <defs>
    <pattern id="dots" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
      <circle cx="20" cy="20" r="2" fill="#e5e7eb"/>
    </pattern>
  </defs>
  <rect width="1200" height="675" fill="url(#dots)"/>
  
  <!-- Dumbbell icon -->
  <g transform="translate(600, 337.5)">
    <!-- Left weight -->
    <rect x="-280" y="-40" width="80" height="80" fill="#9ca3af" rx="8"/>
    <rect x="-270" y="-30" width="60" height="60" fill="#d1d5db" rx="4"/>
    
    <!-- Bar -->
    <rect x="-200" y="-15" width="400" height="30" fill="#6b7280" rx="4"/>
    <line x1="-180" y1="-20" x2="-180" y2="20" stroke="#4b5563" stroke-width="2"/>
    <line x1="180" y1="-20" x2="180" y2="20" stroke="#4b5563" stroke-width="2"/>
    
    <!-- Right weight -->
    <rect x="200" y="-40" width="80" height="80" fill="#9ca3af" rx="8"/>
    <rect x="210" y="-30" width="60" height="60" fill="#d1d5db" rx="4"/>
  </g>
  
  <!-- Text -->
  <text x="600" y="580" font-family="system-ui, -apple-system, sans-serif" font-size="28" fill="#6b7280" text-anchor="middle" font-weight="500">
    Exercise Image Unavailable
  </text>
</svg>
