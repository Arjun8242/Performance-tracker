# Core server
PORT=3000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/ai-fitness

# JWT
# Must be at least 32 random characters
JWT_SECRET=replace-with-long-random-secret-string-at-least-32-chars
JWT_ACCESS_EXPIRATION_MINUTES=30

# Frontend CORS origin
# Example for local Vite dev server
FRONTEND_URL=http://localhost:5173

# Email (required in production for OTP)
GMAIL_EMAIL=your-gmail-address@example.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Google Gemini API (optional but required for AI features)
GEMINI_API_KEY=your-gemini-api-key
